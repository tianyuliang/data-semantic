# 构建阶段
FROM golang:1.25-alpine AS builder

WORKDIR /build

# 安装依赖和工具
RUN apk add --no-cache \
    git \
    ca-certificates \
    tzdata

# 复制依赖文件
COPY go.mod go.sum ./
RUN go mod download

# 复制源代码
COPY . .

# 编译 Consumer 服务
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build \
    -ldflags="-s -w" \
    -o /app/consumer ./consumer/main.go

# 运行阶段
FROM alpine:3.20

RUN apk --no-cache add \
    ca-certificates \
    tzdata

WORKDIR /app

# 创建非 root 用户
RUN addgroup -g 1000 appuser && \
    adduser -D -u 1000 -G appuser appuser

# 从构建阶段复制
COPY --from=builder /app/consumer .
COPY --from=builder /build/consumer/etc ./etc

# 设置时区
ENV TZ=Asia/Shanghai

USER appuser

CMD ["./consumer", "-f", "etc/consumer.yaml"]
